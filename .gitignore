# Uncomment the next line if you don't want to track it
# .terraform.lock.hcl

# CLI configuration files
terraform.rc
.terraformrc

# Environment files
.env
.env.*

# IDE files
.vscode/
.idea/

# OS files
.DS_Store
Thumbs.db